# Backend Environment Variables for Hugging Face Spaces
# Copy this file to .env and fill in your values

# OpenAI API Configuration (optional - if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Configuration (optional - if using Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model Selection (options: "gemini", "openai")
AI_MODEL=gemini

# Server Configuration (HF Spaces uses PORT=7860 by default)
HOST=0.0.0.0
PORT=7860

# CORS Settings (comma-separated origins)
# Add your HF Spaces URL and Vercel frontend URL
ALLOWED_ORIGINS=https://vickey92-cv.hf.space,https://portfolio-xi-seven-67.vercel.app,http://localhost:3000,http://localhost:3001

# Application Settings
APP_NAME="Shoaib Arshad Portfolio API"
DEBUG=false
